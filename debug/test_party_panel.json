{
  "name": "Party Panel — labels visible",
  "default_timeout_sec": 60,
  "steps": [
    {
      "type": "wait_for",
      "event": "bridge_ready",
      "desc": "DebugBridge active"
    },
    {
      "type": "wait_for",
      "event": "screen_ready",
      "scene": "MainMenu",
      "desc": "Main menu loaded — world should be auto-selected",
      "timeout_sec": 30
    },
    {
      "type": "cmd",
      "desc": "Click Play",
      "payload": {"cmd": "click", "target": "PlayBtn"}
    },
    {
      "type": "wait_for",
      "event": "screen_ready",
      "scene": "GameWorld",
      "desc": "Game world ready",
      "timeout_sec": 90
    },
    {
      "type": "cmd",
      "desc": "Press P to open party panel",
      "payload": {"cmd": "press_key", "keycode": "P"}
    },
    {
      "type": "assert",
      "event": "screen_ready",
      "scene": "GameWorld",
      "panel": "PartyPanel",
      "desc": "Party panel opened and reported its nodes",
      "timeout_sec": 10
    },
    {
      "type": "cmd",
      "desc": "Quit",
      "payload": {"cmd": "quit"}
    }
  ]
}
