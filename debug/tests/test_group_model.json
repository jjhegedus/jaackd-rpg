{
  "name": "Group model — all characters have valid solo groups",
  "default_timeout_sec": 60,
  "steps": [
    {
      "type": "wait_for",
      "event": "bridge_ready",
      "desc": "DebugBridge active"
    },
    {
      "type": "wait_for",
      "event": "screen_ready",
      "scene": "MainMenu",
      "desc": "Main menu loaded",
      "timeout_sec": 30
    },
    {
      "type": "cmd",
      "desc": "Click Play to enter GameWorld",
      "payload": {"cmd": "click", "target": "PlayBtn"}
    },
    {
      "type": "wait_for",
      "event": "screen_ready",
      "scene": "GameWorld",
      "desc": "Game world ready (entities and groups registered)",
      "timeout_sec": 90
    },
    {
      "type": "cmd",
      "desc": "Verify all characters have groups and groups have members",
      "payload": {"cmd": "verify_groups"}
    },
    {
      "type": "check",
      "event": "groups_verified",
      "fields": {"ok": true},
      "desc": "All characters have valid groups",
      "timeout_sec": 10
    },
    {
      "type": "cmd",
      "desc": "Quit",
      "payload": {"cmd": "quit"}
    }
  ]
}
