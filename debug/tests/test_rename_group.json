{
  "name": "Group rename — inline rename via command panel",
  "default_timeout_sec": 30,
  "steps": [
    {
      "type": "wait_for",
      "event": "bridge_ready",
      "desc": "DebugBridge active"
    },
    {
      "type": "wait_for",
      "event": "screen_ready",
      "scene": "MainMenu",
      "desc": "Main menu loaded",
      "timeout_sec": 30
    },
    {
      "type": "cmd",
      "desc": "Click Play",
      "payload": {"cmd": "click", "target": "PlayBtn"}
    },
    {
      "type": "wait_for",
      "event": "screen_ready",
      "scene": "GameWorld",
      "panel": "CommandPanel",
      "desc": "CommandPanel ready with group rows",
      "timeout_sec": 30
    },
    {
      "type": "cmd",
      "desc": "Click rename button on first group row",
      "payload": {"cmd": "click", "target": "rename_btn_0"}
    },
    {
      "type": "wait_for",
      "event": "screen_ready",
      "scene": "GameWorld",
      "panel": "CommandPanel",
      "desc": "CommandPanel re-rendered with LineEdit",
      "timeout_sec": 10
    },
    {
      "type": "cmd",
      "desc": "Type new group name",
      "payload": {"cmd": "set_text", "target": "rename_edit_0", "value": "Vanguard"}
    },
    {
      "type": "cmd",
      "desc": "Submit with Enter",
      "payload": {"cmd": "press_key", "keycode": "Enter"}
    },
    {
      "type": "check",
      "event": "screen_ready",
      "desc": "CommandPanel re-rendered with new name",
      "fields": {"panel": "CommandPanel", "scene": "GameWorld"},
      "timeout_sec": 10
    },
    {
      "type": "cmd",
      "desc": "Quit",
      "payload": {"cmd": "quit"}
    }
  ]
}
